{
  "name": "chatapp-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Express backend for ChatApp",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "google-auth-library": "^10.6.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.0",
    "nodemailer": "^8.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "js,mjs,json",
    "ignore": [
      "node_modules"
    ]
  }
}
